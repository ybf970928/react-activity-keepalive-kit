{
  "name": "react-activity-keepalive-kit",
  "version": "0.1.1",
  "description": "A KeepAlive component for React 19.2+ built on top of the official <Activity> API, with LRU/PRE cache strategies and an imperative ref API.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "react",
    "react19",
    "activity",
    "keep-alive",
    "keepalive",
    "cache",
    "lru",
    "tab-cache",
    "component-cache",
    "router-cache"
  ],
  "author": "ybf970928",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ybf970928/react-activity-keepalive-kit"
  },
  "homepage": "https://github.com/ybf970928/react-activity-keepalive-kit",
  "bugs": {
    "url": "https://github.com/ybf970928/react-activity-keepalive-kit/issues"
  },
  "peerDependencies": {
    "react": ">=19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "react": "^19.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
